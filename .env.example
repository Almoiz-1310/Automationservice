PORT=3000
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=automation@your-company.com
JIRA_API_TOKEN=replace-me
JIRA_WEBHOOK_SECRET=replace-me
GITHUB_TOKEN=replace-me
GITHUB_REPO=your-org/ai-content-studio
LLM_API_KEY=replace-me
LLM_MODEL=gpt-4.1-mini

# memory = in-process only (lost on restart). file = persistent single-instance dedupe.
IDEMPOTENCY_BACKEND=file
IDEMPOTENCY_FILE_DIR=./data/idempotency

ALLOWED_JIRA_PROJECTS=ACS
ALLOWED_JIRA_ISSUE_TYPES=Feature,Story
REQUIRED_JIRA_LABEL=
